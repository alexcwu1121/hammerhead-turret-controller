FILE_TYPE=LIBRARY_PARTS;
PRIMITIVE 'TPS54202DDCR','TPS54202DDCR_SOT23 (6-Pin)';
  PIN
    'GND':
      PIN_NUMBER='(1)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='GROUND';
    'SW':
      PIN_NUMBER='(2)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='OUTPUT';
    'VIN':
      PIN_NUMBER='(3)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='POWER';
    'BOOT':
      PIN_NUMBER='(6)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='OUTPUT';
    'EN':
      PIN_NUMBER='(5)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='INPUT';
    'FB':
      PIN_NUMBER='(4)';
      NO_LOAD_CHECK=BOTH;
      NO_IO_CHECK=BOTH;
      ALLOW_CONNECT=TRUE;
      PINUSE='INPUT';
  END_PIN;
  BODY
    PART_NAME='TPS54202DDCR';
    PHYS_DES_PREFIX='PS';
    NO_LOAD_CHECK='TRUE';
    PIN_COUNT='6';
    BODY_NAME='TPS54202DDCR';
    JEDEC_TYPE='SOT95P280X110-6N';
  END_BODY;
END_PRIMITIVE;
END.
